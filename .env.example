# PostgreSQL / TimescaleDB
POSTGRES_DB=stonky
POSTGRES_USER=stonky
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Backend — async SQLAlchemy connection URL
DATABASE_URL=postgresql+asyncpg://stonky:changeme@localhost:5432/stonky

# FastAPI
DEBUG=false
CORS_ORIGINS=["http://localhost:5173"]

# Pipeline concurrency (tune based on hardware)
PIPELINE_YOLO_CONCURRENCY=4      # reduce to 2 if using GPU for YOLO
PIPELINE_CHRONOS_CONCURRENCY=4
PIPELINE_SYNTHESIS_CONCURRENCY=1  # do not change — Ollama is single-threaded

# LLM Synthesis Agent
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
# ANTHROPIC_API_KEY=  # uncomment when switching to Claude
