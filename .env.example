# PostgreSQL / TimescaleDB
POSTGRES_DB=stonky
POSTGRES_USER=stonky
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Backend — async SQLAlchemy connection URL
DATABASE_URL=postgresql+asyncpg://stonky:changeme@localhost:5432/stonky

# FastAPI
DEBUG=false
CORS_ORIGINS=["http://localhost:5173"]

# LLM Synthesis Agent
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
# ANTHROPIC_API_KEY=  # uncomment when switching to Claude
